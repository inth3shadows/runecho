#!/usr/bin/env python3
"""Detector: i18n key references with no declaration in any locale file.

Fronts nothing — and that is itself a Gate-3 finding. The incumbents evaluated
(i18next-cli `extract --ci`, i18nGuard, i18n-cleaner) all require per-project i18n
configuration (which files are locales, namespace layout, framework), so none runs
as a config-free sweep over an arbitrary repo. So this does minimal deterministic
extraction ITSELF, for triage MEASUREMENT only. It is not the check RunEcho would
ship: if this class ever clears Gate 4, the shipping detector should still front a
configured incumbent (docs/check-worthiness.md Gate 3). Here it exists to answer
"how often does this defect actually occur, and at what FP rate" — and to test
whether the triage plugin contract holds for a check shaped nothing like the CSS
one (JS/TS surface, JSON declarations, dotted-key symbols).

Contract (identical to every triage detector — this is the point of the test):
argv[1] is a repo path; print a JSON list of {"file","line","symbol"} to stdout;
exit 0 clean, 1 with findings, >=2 = the detector itself failed.

Deliberately FP-conservative — it ABSTAINS rather than guesses, because a triage
detector's noise becomes the measured FP rate and a blocking gate built on it
would block correct writes:
  - Dynamic keys (t(`a.${x}`)) can't be resolved statically → never flagged.
  - A repo with no locale files isn't doing i18n → abstain (exit 0, empty),
    mirroring the CSS detector on a repo with no custom properties.
  - A key present in ANY locale counts as declared; missing-in-SOME-locale is a
    different defect (incomplete translation), out of scope here.
"""

import json
import os
import re
import sys

GENERATED = ("/node_modules/", "/dist/", "/build/", "/.next/", "/out/",
             "/coverage/", "/vendor/", "/.venv/", "/target/")
CODE_EXT = (".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs", ".vue")
LOCALE_DIR = re.compile(r"/(locales?|i18n|lang|messages|translations?)/", re.I)

# Reference forms. The string body is (['"])((?:\\.|(?!\1).)*)\1 — capture the
# OPENING delimiter in group 1, then read until the SAME delimiter, allowing the
# other quote inside. A naive [^'"]+ truncates "You don't..." to "You don" at the
# apostrophe, and English UI copy used as natural-language keys is full of
# apostrophes — that one bug produced 20 of 26 false positives on the first real
# corpus. Template literals (backtick) are still unmatched on purpose: a dynamic
# key is unresolvable and flagging it would be a guaranteed false positive.
_STR = r"""(['"])((?:\\.|(?!\1).)*)\1"""
REF_PATTERNS = [
    re.compile(r"\bt\(\s*" + _STR),          # t('a.b') / t("a.b")
    re.compile(r"\$t\(\s*" + _STR),          # Vue $t('a.b')
    re.compile(r"\bi18nKey\s*=\s*" + _STR),  # <Trans i18nKey="a.b">
]
# The key is capture group 2 (group 1 is the delimiter).
_KEY_GROUP = 2


def strip_comments(src: str) -> str:
    """Blank // and /* */ comments while preserving string contents.

    Comment-blanking, not removal: replace comment characters with spaces so line
    numbers and column positions are unchanged (findings must point at the real
    line). String bodies are kept verbatim — they hold the keys — so a // or /*
    inside a string is NOT treated as a comment. Without this, excalidraw's
    /*-doc block listing i18nKey="example1".. and outline's //-config examples
    read as live references (6 of 26 false positives on the first real corpus).
    """
    out = []
    i, n = 0, len(src)
    quote = ""          # current string delimiter, or "" outside a string
    while i < n:
        c = src[i]
        if quote:
            out.append(c)
            if c == "\\" and i + 1 < n:      # escape: copy the next char whole
                out.append(src[i + 1]); i += 2; continue
            if c == quote:
                quote = ""
            i += 1
            continue
        # not in a string
        if c in "'\"`":
            quote = c; out.append(c); i += 1; continue
        if c == "/" and i + 1 < n and src[i + 1] == "/":
            while i < n and src[i] != "\n":  # line comment → spaces to EOL
                out.append(" "); i += 1
            continue
        if c == "/" and i + 1 < n and src[i + 1] == "*":
            while i < n and not (src[i] == "*" and i + 1 < n and src[i + 1] == "/"):
                out.append("\n" if src[i] == "\n" else " "); i += 1
            if i < n:
                out.append("  "); i += 2      # blank the closing */
            continue
        out.append(c); i += 1
    return "".join(out)


def _is_generated(path: str) -> bool:
    return any(m in path for m in GENERATED)


def _walk(repo: str):
    for root, dirs, files in os.walk(repo):
        # Prune generated dirs in place so os.walk never descends them.
        dirs[:] = [d for d in dirs
                   if not _is_generated(os.path.join(root, d) + "/")]
        for f in files:
            yield os.path.join(root, f)


def _flatten(obj, prefix, out):
    """Flatten nested locale JSON to dotted keys: {a:{b:1}} -> {'a.b'}."""
    if isinstance(obj, dict):
        for k, v in obj.items():
            _flatten(v, f"{prefix}.{k}" if prefix else k, out)
    else:
        # Leaf (string / number / array) — this dotted path is a declared key.
        if prefix:
            out.add(prefix)


def collect_declared(repo: str):
    """Union of dotted keys across all locale JSON files, plus namespace names.

    Namespaces: i18next writes each namespace to its own file (common.json,
    errors.json), and code references them as t('common:save'). So the file
    stem is a namespace, and a key inside it is reachable as both 'save' (within
    that ns) and 'common:save'. Both forms are recorded so either reference
    style resolves.
    """
    keys = set()
    namespaces = set()
    found_any = False
    for path in _walk(repo):
        if not path.endswith(".json") or not LOCALE_DIR.search(path):
            continue
        try:
            with open(path, encoding="utf-8") as fh:
                data = json.load(fh)
        except (OSError, json.JSONDecodeError, UnicodeDecodeError):
            # A malformed locale file is not a code defect; skip it. (It is also
            # not proof of "no i18n" — found_any is only set on a parse success.)
            continue
        found_any = True
        ns = os.path.splitext(os.path.basename(path))[0]
        namespaces.add(ns)
        local = set()
        _flatten(data, "", local)
        keys |= local
        keys |= {f"{ns}:{k}" for k in local}  # namespace-qualified form
    return keys, namespaces, found_any


def extract_refs(repo: str):
    """Yield (file, line, key) for every static i18n key reference in code.

    Comments are blanked file-wide first (a /* */ block spans lines), then each
    line is scanned. strip_comments preserves line breaks, so a per-line index
    after it still points at the true source line.
    """
    for path in _walk(repo):
        if not path.endswith(CODE_EXT):
            continue
        try:
            with open(path, encoding="utf-8") as fh:
                src = fh.read()
        except (OSError, UnicodeDecodeError):
            continue
        for lineno, line in enumerate(strip_comments(src).splitlines(), 1):
            for pat in REF_PATTERNS:
                for m in pat.finditer(line):
                    key = m.group(_KEY_GROUP)
                    # Interpolation inside the literal ("Hi {{name}}") — the
                    # catalog key includes the placeholder verbatim, so keep it;
                    # only a truly empty capture is dropped.
                    if key:
                        yield path, lineno, key


# i18next plural/context suffixes. A reference t("x", {count}) resolves against
# x_one / x_other / … in the catalog, never a bare "x" — so a plural key looks
# "missing" unless the suffixed forms are checked. This modelled 1 of the 4
# residual false positives on the real corpus; leaving it out means the detector
# flags every pluralized string, which is most user-facing counts.
_PLURAL_SUFFIXES = ("_zero", "_one", "_two", "_few", "_many", "_other", "_plural")

_ESCAPE = re.compile(r"\\u\{([0-9A-Fa-f]+)\}|\\u([0-9A-Fa-f]{4})|\\x([0-9A-Fa-f]{2})")
_SIMPLE_ESCAPE = {"\\n": "\n", "\\t": "\t", "\\r": "\r", "\\\\": "\\",
                  "\\'": "'", '\\"': '"', "\\`": "`", "\\/": "/"}


def decode_js_escapes(s: str) -> str:
    """Decode the JS string escapes that survive into a captured key.

    The KEY is the string's RUNTIME value; i18next-parser writes the decoded form
    into the catalog. Source that writes "… \\u2013 …" (a literal backslash-u) is
    the en-dash at runtime and in the catalog, so an undecoded capture never
    matches (1 of the 4 residual FPs on the real corpus). Targeted, not a blanket
    unicode_escape decode, which would corrupt keys that already contain real
    UTF-8 characters.
    """
    def sub(m):
        h = m.group(1) or m.group(2) or m.group(3)
        try:
            return chr(int(h, 16))
        except (ValueError, OverflowError):
            return m.group(0)
    s = _ESCAPE.sub(sub, s)
    for k, v in _SIMPLE_ESCAPE.items():
        s = s.replace(k, v)
    return s


def resolves(key: str, declared: set, namespaces: set) -> bool:
    key = decode_js_escapes(key)
    if key in declared:
        return True
    if any(f"{key}{suf}" in declared for suf in _PLURAL_SUFFIXES):
        return True
    # 'ns:rest' — declared already holds 'ns:rest' forms, but also accept a bare
    # 'rest' matching when the ns is a known file, for catalogs that don't nest.
    if ":" in key:
        ns, _, rest = key.partition(":")
        if ns in namespaces and (
            rest in declared or key in declared
            or any(f"{rest}{suf}" in declared for suf in _PLURAL_SUFFIXES)
        ):
            return True
    return False


def main() -> int:
    if len(sys.argv) != 2:
        sys.exit("usage: i18n-keys <repo-path>")
    repo = os.path.abspath(os.path.expanduser(sys.argv[1]))
    if not os.path.isdir(repo):
        sys.exit(f"i18n-keys: not a directory: {repo}")

    declared, namespaces, found_any = collect_declared(repo)
    if not found_any:
        # No locale catalog → repo isn't doing i18n → abstain. Empty result,
        # exit 0. NOT a crash and NOT "clean with confidence" — there was simply
        # nothing to check, the same posture the CSS detector takes on a repo
        # with no custom properties.
        print("[]")
        return 0

    findings = []
    for path, lineno, key in extract_refs(repo):
        if not resolves(key, declared, namespaces):
            findings.append({"file": path, "line": lineno, "symbol": key})

    json.dump(findings, sys.stdout)
    # Contract: 1 when findings exist, 0 when clean. triage.py accepts both.
    return 1 if findings else 0


if __name__ == "__main__":
    sys.exit(main())
